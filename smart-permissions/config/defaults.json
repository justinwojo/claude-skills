  "safe_write_paths": [
    "~/Dev/",
    "/tmp/",
    "/private/tmp/",
    "/var/folders/",
    "/private/var/folders/",
    "~/.claude/"
  ],

  "safe_script_paths": [
    "~/Dev/",
    "/tmp/",
    "/private/tmp/",
    "/usr/local/bin/",
    "/usr/local/share/",
    "/opt/homebrew/bin/"
  ],

  "allowed_web_domains": [
    "github.com",
    "raw.githubusercontent.com",
    "stackoverflow.com",
    "developer.apple.com",
    "learn.microsoft.com",
    "docs.python.org",
    "docs.rs",
    "pkg.go.dev",
    "npmjs.com",
    "pypi.org",
    "crates.io"
  ],

  "sensitive_paths": [
    "/.ssh/",
    "/.aws/",
    "/.config/gh/",
    "/.env"
  ],

  "dangerous_patterns": [
    "\\bsudo\\b",
    "\\brm\\s+(-[a-zA-Z]*)?r[a-zA-Z]*f[a-zA-Z]*\\s+/(\\s|$)",
    "\\brm\\s+(-[a-zA-Z]*)?f[a-zA-Z]*r[a-zA-Z]*\\s+/(\\s|$)",
    "\\brm\\s+(-\\S+\\s+)*['\"]\\/(\\s|$|['\"])",
    ">\\s*/dev/(?!null)",
    "\\bmkfs\\b",
    "\\bdd\\b.*\\bof=/dev/",
    ":\\s*\\(\\)\\s*\\{.*\\|.*&",
    "\\bcurl\\b.*\\|\\s*(ba)?sh\\b",
    "\\bwget\\b.*\\|\\s*(ba)?sh\\b",
    "\\b(ba)?sh\\s+<\\s*\\(\\s*(curl|wget)\\b",
    "\\bsource\\s+<\\s*\\(\\s*(curl|wget)\\b"
  ],

  "risky_patterns": [
    "\\brm\\s+(-\\S+\\s+)*(\\.\\*|\\*)(\\s|$)",
    "\\bfind\\s+/\\s.*-delete\\b",
    "\\bfind\\s+/\\s.*-exec\\s+rm\\b",
    "\\b(tar|unzip|cpio)\\b.*(-C|--directory|-d)\\s+['\"]?/(?:usr|etc|bin|sbin|System|Library)?/?['\"]?(\\s|$)",
    "__ download-and-execute chain: curl/wget then run interpreter on a temp file __",
    "\\b(curl|wget)\\b[^|&;]*[;&|]+[^|&;]*\\b(bash|sh|zsh|python[0-9.]*|node|ruby|perl|deno|osascript)\\s+(/private)?/(tmp|var/folders)/"
  ],

  "interpreter_exec_flags": {
    "bash": ["-c"],
    "sh": ["-c"],
    "zsh": ["-c"],
    "fish": ["-c"],
    "osascript": ["-e"],
    "python": ["-c"],
    "python3": ["-c"],
    "python3.11": ["-c"],
    "python3.12": ["-c"],
    "python3.13": ["-c"],
    "perl": ["-e", "-E"],
    "ruby": ["-e"],
    "node": ["-e", "-p", "--eval", "--print"],
    "deno": ["eval"]
  }
