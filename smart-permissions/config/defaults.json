{
  "_comment": "Default configuration for smart-permissions hook. Override any section by creating ~/.claude/smart-permissions-config.json with the keys you want to change. Arrays are merged (union), not replaced. Commands support multi-word entries ('flutter doctor') and wildcards ('kubectl get*').",

  "safe_commands": [
    "__ Dev tools __",
    "dotnet", "git", "just", "npx", "claude",
    "make", "cmake", "rustc", "go", "node",
    "python", "python3", "ruby", "perl", "swift", "swiftc",
    "xcodebuild", "xcrun", "xcode-select", "brew", "nuget",

    "__ Package managers (publish commands prompt) __",
    "npm ci", "npm install", "npm test", "npm run *", "npm list", "npm ls",
    "npm outdated", "npm info", "npm view", "npm explain", "npm why",
    "npm init", "npm pkg *", "npm exec *", "npm config *",
    "npm cache *", "npm prefix", "npm root", "npm bin", "npm help",
    "npm audit", "npm fund", "npm pack", "npm link", "npm unlink",
    "npm update", "npm prune", "npm dedupe", "npm rebuild", "npm start",
    "npm stop", "npm restart", "npm explore *", "npm edit *",
    "pnpm install", "pnpm test", "pnpm run *", "pnpm list",
    "pnpm outdated", "pnpm audit", "pnpm exec *", "pnpm dlx *",
    "pnpm add *", "pnpm remove *", "pnpm update *", "pnpm link *",
    "pnpm rebuild", "pnpm start", "pnpm cache *", "pnpm why *",
    "yarn install", "yarn test", "yarn run *", "yarn list",
    "yarn info", "yarn why", "yarn add *", "yarn remove *",
    "yarn upgrade *", "yarn cache *", "yarn link *", "yarn unlink *",
    "yarn start", "yarn build", "yarn dev",
    "pip install *", "pip list", "pip show *", "pip freeze",
    "pip check", "pip download *", "pip wheel *", "pip hash *",
    "pip search *", "pip cache *", "pip config *", "pip debug",
    "poetry install", "poetry add *", "poetry remove *", "poetry update *",
    "poetry show *", "poetry lock", "poetry check", "poetry run *",
    "poetry build", "poetry env *", "poetry config *", "poetry cache *",
    "cargo build *", "cargo test *", "cargo check *", "cargo run *",
    "cargo bench *", "cargo doc *", "cargo clean", "cargo update *",
    "cargo add *", "cargo remove *", "cargo fix *", "cargo clippy *",
    "cargo fmt *", "cargo tree *", "cargo metadata",
    "cargo generate-lockfile", "cargo verify-project",

    "__ Docker (run/exec/push prompt) __",
    "docker build *", "docker compose *", "docker-compose *",
    "docker ps *", "docker images *", "docker image *",
    "docker logs *", "docker inspect *", "docker info",
    "docker version", "docker volume *", "docker network *",
    "docker tag *", "docker pull *", "docker cp *",
    "docker stats *", "docker top *", "docker port *",
    "docker diff *", "docker history *", "docker manifest *",
    "docker system *", "docker context *", "docker buildx *",
    "docker container ls *", "docker container list *",
    "docker container inspect *", "docker container logs *",
    "docker container stats *", "docker container top *",
    "docker container port *", "docker container diff *",
    "docker stop *", "docker start *", "docker restart *",
    "docker pause *", "docker unpause *", "docker wait *",
    "docker create *", "docker rm *",

    "__ GitHub CLI (read-only auto-allowed, mutations prompt) __",
    "gh pr view *", "gh pr list *", "gh pr status", "gh pr checks *",
    "gh pr diff *",
    "gh issue view *", "gh issue list *", "gh issue status",
    "gh repo view *", "gh repo list *", "gh repo clone *",
    "gh run view *", "gh run list *", "gh run watch *",
    "gh release view *", "gh release list *",
    "gh auth status",
    "gh search *", "gh browse *", "gh gist view *", "gh gist list *",
    "gh status", "gh label list *", "gh config *",

    "__ System utilities __",
    "tree", "ls", "pwd", "which", "env", "export", "source",
    "cd", "echo", "cat", "head", "tail", "wc", "tee", "file",
    "du", "df", "test", "sleep", "printf", "date", "uname",
    "open", "pbcopy", "pbpaste", "paste", "xattr", "exit",
    "xmllint", "sips",

    "__ File operations __",
    "mkdir", "touch", "cp", "mv", "rm", "rmdir", "ln",
    "chmod", "chown", "tar", "zip", "unzip",

    "__ Search and text tools __",
    "grep", "rg", "find", "fd", "jq", "yq",
    "sed", "awk", "sort", "uniq", "diff", "patch", "xargs",
    "cut", "tr", "column", "comm",

    "__ Binary inspection and hash utilities __",
    "nm", "otool", "lipo", "codesign", "plutil", "vtool", "defaults", "strings",
    "md5", "stat", "xxd", "shasum", "sha256sum",

    "__ Compilers __",
    "clang", "clang++", "gcc", "g++", "cc", "c++",

    "__ Process management __",
    "ps", "pkill", "killall", "kill", "lsof", "timeout", "gtimeout", "time",

    "__ Network __",
    "curl", "wget",

    "__ Modern CLI tools __",
    "eza", "bat", "repomix",

    "__ Shell builtins and meta __",
    "!", "bash", "sh", "zsh", "true", "false", "command", "type",
    "set", "[", "[[",
    "local", "return", "declare", "typeset", "readonly", "unset",
    "eval", "exec", "read", "trap", "wait", "shift",
    "function", "{", "}",

    "__ Shell flow-control keywords __",
    "for", "do", "done", "while", "until",
    "if", "then", "else", "elif", "fi",
    "case", "esac", "in", "select",
    "break", "continue",

    "__ Path utilities __",
    "basename", "dirname", "realpath", "readlink"
  ],

  "safe_write_paths": [
    "~/Dev/",
    "/tmp/",
    "/private/tmp/",
    "/var/folders/",
    "/private/var/folders/",
    "~/.claude/"
  ],

  "safe_script_paths": [
    "~/Dev/",
    "/tmp/",
    "/private/tmp/",
    "/usr/local/bin/",
    "/usr/local/share/",
    "/opt/homebrew/bin/"
  ],

  "allowed_web_domains": [
    "github.com",
    "raw.githubusercontent.com",
    "stackoverflow.com",
    "developer.apple.com",
    "learn.microsoft.com",
    "docs.python.org",
    "docs.rs",
    "pkg.go.dev",
    "npmjs.com",
    "pypi.org",
    "crates.io"
  ],

  "sensitive_paths": [
    "/.ssh/",
    "/.aws/",
    "/.config/gh/",
    "/.env"
  ],

  "dangerous_patterns": [
    "\\bsudo\\b",
    "\\brm\\s+(-[a-zA-Z]*)?r[a-zA-Z]*f[a-zA-Z]*\\s+/(\\s|$)",
    "\\brm\\s+(-[a-zA-Z]*)?f[a-zA-Z]*r[a-zA-Z]*\\s+/(\\s|$)",
    "\\brm\\s+(-\\S+\\s+)*['\"]\\/(\\s|$|['\"])",
    ">\\s*/dev/(?!null)",
    "\\bmkfs\\b",
    "\\bdd\\b.*\\bof=/dev/",
    ":\\s*\\(\\)\\s*\\{.*\\|.*&",
    "\\bcurl\\b.*\\|\\s*(ba)?sh\\b",
    "\\bwget\\b.*\\|\\s*(ba)?sh\\b",
    "\\b(ba)?sh\\s+<\\s*\\(\\s*(curl|wget)\\b",
    "\\bsource\\s+<\\s*\\(\\s*(curl|wget)\\b"
  ],

  "risky_patterns": [
    "\\brm\\s+(-\\S+\\s+)*(\\.\\*|\\*)(\\s|$)",
    "\\bfind\\s+/\\s.*-delete\\b",
    "\\bfind\\s+/\\s.*-exec\\s+rm\\b",
    "\\b(tar|unzip|cpio)\\b.*(-C|--directory|-d)\\s+['\"]?/(?:usr|etc|bin|sbin|System|Library)?/?['\"]?(\\s|$)"
  ],

  "interpreter_exec_flags": {
    "bash": ["-c"],
    "sh": ["-c"],
    "zsh": ["-c"],
    "osascript": ["-e"]
  }
}
